{% extends 'base.html.twig' %}

{% block body %}
    <h1>Import Clubs from CSV</h1>

    {% if message %}
        <div class="alert alert-info">{{ message }}</div>
    {% endif %}

    {{ form_start(form) }}
        {{ form_row(form.csv) }}
        <button class="btn btn-primary">Upload</button>
    {{ form_end(form) }}
{% endblock %}